{
  "name": "turborepo-next-nest",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "free-ports": "lsof -ti:3000,3001 | xargs kill -9 2>/dev/null || true",
    "dev": "pnpm run free-ports && turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "prepare": "husky install"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.0"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "apps/backend/**/*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "apps/frontend/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
